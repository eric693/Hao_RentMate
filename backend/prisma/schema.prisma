datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  STAFF
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(ADMIN)
  ownerId   String?  // STAFF：所屬管理員(資料擁有者) id；ADMIN：null（資料擁有者為自己）
  permissions String[] @default([]) // STAFF 可存取的模組鍵；ADMIN 不受限
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner            User?    @relation("OwnerStaff", fields: [ownerId], references: [id], onDelete: Cascade)
  staff            User[]   @relation("OwnerStaff")
  properties       Property[]
  tenants          Tenant[]
  lineBinding      LineBinding?
  reminderSetting  ReminderSetting?
}

model Property {
  id            String   @id @default(cuid())
  userId        String
  name          String
  address       String
  district      String?  // 行政區（租金行情分群用，未填則由 address 推斷）
  description   String?
  purchasePrice Decimal? @db.Decimal(14, 2)
  createdAt     DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  units        Unit[]
  expenses     Expense[]
  utilityBills UtilityBill[]
}

model Unit {
  id          String     @id @default(cuid())
  propertyId  String
  unitNumber  String
  floor       Int?
  type        String?
  monthlyRent Decimal    @db.Decimal(10, 2)
  status      UnitStatus @default(VACANT)
  areaPing    Decimal?   @db.Decimal(6, 2) // 坪數/面積（水電分攤、租金行情用）
  occupants   Int?       // 居住人數（水電分攤人頭法用）
  tempControl String?    // 溫控類型：常溫 / 冷藏 / 冷凍
  palletSlots Int?       // 棧板位數
  description String?
  createdAt   DateTime   @default(now())

  property            Property             @relation(fields: [propertyId], references: [id])
  contracts           Contract[]
  maintenanceRequests MaintenanceRequest[]
  expenses            Expense[]
  listings            ListingRecord[]
  utilityAllocations  UtilityAllocation[]
}

enum UnitStatus {
  VACANT
  OCCUPIED
}

model Tenant {
  id               String    @id @default(cuid())
  userId           String
  name             String
  phone            String
  email            String?
  idNumber         String?
  emergencyContact String?
  lineUserId       String?   @unique
  lineDisplayName  String?
  lineBindingCode  String?
  lineBindingCodeExpiry DateTime?
  lineBoundAt      DateTime?
  createdAt        DateTime  @default(now())

  user                User                 @relation(fields: [userId], references: [id])
  contracts           Contract[]
  maintenanceRequests MaintenanceRequest[]
  creditSnapshot      TenantCreditSnapshot?
}

model Contract {
  id            String         @id @default(cuid())
  unitId        String
  tenantId      String
  startDate     DateTime
  endDate       DateTime
  monthlyRent   Decimal        @db.Decimal(10, 2)
  depositAmount Decimal        @db.Decimal(10, 2)
  depositPaid   Boolean        @default(false)
  rentDueDay    Int            @default(5)
  status        ContractStatus @default(ACTIVE)
  notes         String?
  customTerms   String?        // 房東自訂租賃條款（每行一條）；空值時簽署頁顯示預設條款
  signToken     String?        @unique
  signedAt      DateTime?
  signerName    String?
  signerIdDocument String?      // 簽署時上傳的證件影像路徑（身分驗證用）
  createdAt     DateTime       @default(now())

  // 合規檢查結果（內政部定型化契約應記載/不得記載事項）
  complianceResult    Json?
  complianceCheckedAt DateTime?

  unit           Unit            @relation(fields: [unitId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  rentRecords    RentRecord[]
  depositRefund  DepositRefund?
  virtualAccount VirtualAccount?
  payments       Payment[]
  handovers      Handover[]
}

model DepositRefund {
  id              String              @id @default(cuid())
  contractId      String              @unique
  depositAmount   Decimal             @db.Decimal(10, 2)
  totalDeductions Decimal             @db.Decimal(10, 2) @default(0)
  refundAmount    Decimal             @db.Decimal(10, 2)
  status          DepositRefundStatus @default(PENDING)
  refundDate      DateTime?
  notes           String?
  notifiedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  contract   Contract           @relation(fields: [contractId], references: [id])
  deductions DepositDeduction[]
}

model DepositDeduction {
  id              String   @id @default(cuid())
  depositRefundId String
  description     String
  amount          Decimal  @db.Decimal(10, 2)
  category        String   @default("OTHER")

  depositRefund DepositRefund @relation(fields: [depositRefundId], references: [id], onDelete: Cascade)
}

enum DepositRefundStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

model RentRecord {
  id            String     @id @default(cuid())
  contractId    String
  year          Int
  month         Int
  dueDate       DateTime
  amount        Decimal    @db.Decimal(10, 2)
  paidDate      DateTime?
  paidAmount    Decimal?   @db.Decimal(10, 2)
  status        RentStatus @default(PENDING)
  paymentMethod String?
  notes         String?
  createdAt     DateTime   @default(now())

  contract      Contract      @relation(fields: [contractId], references: [id])
  reminderLogs  ReminderLog[]
  payments      Payment[]

  @@unique([contractId, year, month])
}

model ReminderSetting {
  id               String   @id @default(cuid())
  userId           String   @unique
  enabled          Boolean  @default(true)
  daysBefore       Int      @default(3)
  remindOnDue      Boolean  @default(true)
  overdueEnabled   Boolean  @default(true)
  overdueInterval  Int      @default(3)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model ReminderLog {
  id           String   @id @default(cuid())
  rentRecordId String
  triggerKey   String
  sentAt       DateTime @default(now())
  success      Boolean  @default(true)

  rentRecord RentRecord @relation(fields: [rentRecordId], references: [id])

  @@unique([rentRecordId, triggerKey])
}

enum RentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  unitId      String
  tenantId    String?
  title       String
  description String
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(PENDING)
  reportedAt  DateTime            @default(now())
  resolvedAt  DateTime?
  cost        Decimal?            @db.Decimal(10, 2)
  notes       String?
  photos      String[]            @default([])
  category    String?
  aiClassified Boolean            @default(false)
  aiAnalysis  Json?               // { responsibility, costMin, costMax, reasoning, tips }
  source      String              @default("LANDLORD") // LANDLORD | TENANT

  unit   Unit    @relation(fields: [unitId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Expense {
  id          String          @id @default(cuid())
  userId      String?         // 支出擁有者（資料擁有者 id）；未綁定 property/unit 的支出靠此判斷歸屬
  propertyId  String?
  unitId      String?
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  date        DateTime
  description String?
  confirmedAt DateTime?
  createdAt   DateTime        @default(now())

  property Property? @relation(fields: [propertyId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])

  @@index([userId])
}

enum ExpenseCategory {
  WATER
  ELECTRICITY
  GAS
  MANAGEMENT
  REPAIR
  INSURANCE
  INTERNET
  OTHER
}

model ListingRecord {
  id          String   @id @default(cuid())
  unitId      String
  platform    String
  listedAt    DateTime @default(now())
  expiresAt   DateTime?
  url         String?
  status      String   @default("ACTIVE")
  notes       String?

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model LineBinding {
  id                  String    @id @default(cuid())
  userId              String    @unique
  lineUserId          String    @unique
  displayName         String?
  bindingCode         String?
  bindingCodeExpiry   DateTime?
  boundAt             DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ── 金流：虛擬帳號 + 自動對帳 ──────────────────────────────────
model VirtualAccount {
  id            String   @id @default(cuid())
  contractId    String   @unique
  provider      String   @default("SANDBOX") // SANDBOX | LINEPAY | BANK
  bankCode      String   @default("000")
  accountNumber String   @unique
  createdAt     DateTime @default(now())

  contract Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id               String        @id @default(cuid())
  contractId       String?
  rentRecordId     String?
  virtualAccountId String?
  provider         String        @default("SANDBOX")
  providerTxnId    String?       @unique
  amount           Decimal       @db.Decimal(10, 2)
  paidAt           DateTime      @default(now())
  status           PaymentStatus @default(PENDING)
  payerName        String?
  rawPayload       Json?
  reconciledAt     DateTime?
  note             String?
  createdAt        DateTime      @default(now())

  contract       Contract?       @relation(fields: [contractId], references: [id])
  rentRecord     RentRecord?     @relation(fields: [rentRecordId], references: [id])
  virtualAccount VirtualAccount? @relation(fields: [virtualAccountId], references: [id])
}

enum PaymentStatus {
  PENDING   // 已收到入帳但尚未處理
  MATCHED   // 已自動對帳銷帳
  UNMATCHED // 無法自動匹配，需人工處理
  MANUAL    // 人工指定銷帳
}

// ── 點交相冊：搬入/搬出狀況存證，連動押金扣款 ──────────────────────
model Handover {
  id             String         @id @default(cuid())
  contractId     String
  type           HandoverType
  status         HandoverStatus @default(DRAFT)
  // items: [{ id, area, description, condition, photos: string[] }]
  items          Json           @default("[]")
  // meterReadings: { electricity, water, gas }
  meterReadings  Json?
  note           String?
  confirmToken   String?        @unique // 租客 LINE/連結確認用
  tenantSignedAt DateTime?
  signerName     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

enum HandoverType {
  MOVE_IN
  MOVE_OUT
}

enum HandoverStatus {
  DRAFT          // 房東建立中
  PENDING_TENANT // 待租客確認
  CONFIRMED      // 雙方已確認
}

// ── 水電費分攤：一張總單拆給多間房 ────────────────────────────────
model UtilityBill {
  id          String          @id @default(cuid())
  propertyId  String
  category    ExpenseCategory // WATER | ELECTRICITY | GAS
  periodStart DateTime
  periodEnd   DateTime
  totalAmount Decimal         @db.Decimal(10, 2)
  method      String          @default("EVEN") // EVEN | AREA | HEADCOUNT | USAGE
  note        String?
  createdAt   DateTime        @default(now())

  property    Property            @relation(fields: [propertyId], references: [id])
  allocations UtilityAllocation[]
}

model UtilityAllocation {
  id            String   @id @default(cuid())
  utilityBillId String
  unitId        String
  amount        Decimal  @db.Decimal(10, 2)
  basis         Decimal? @db.Decimal(10, 2) // 分攤依據值（用量/坪數/人頭）
  billed        Boolean  @default(false)    // 是否已開帳給租客

  utilityBill UtilityBill @relation(fields: [utilityBillId], references: [id], onDelete: Cascade)
  unit        Unit        @relation(fields: [unitId], references: [id])
}

// ── 租客信用分快照（依繳租紀錄計算，跨房東以身分證字號聚合）──────────
model TenantCreditSnapshot {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  score        Int      // 300-850
  grade        String   // A+ A B C D
  onTimeRate   Float    // 準時繳納比例 0-1
  avgDelayDays Float    // 平均逾期天數
  totalRecords Int      // 納入計算的繳租筆數
  crossLandlord Boolean @default(false) // 是否含跨房東歷史
  computedAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}
